<%- include('partials/header', { title }) %>

<div class="container-fluid flex-grow-1 d-flex flex-column py-3">

  <div class="row flex-grow-1 gy-3">
    <!-- Columna Izquierda: Controles y Mapa -->
    <div class="col-lg-8 d-flex flex-column">
      
      <!-- Panel de estado -->
      <div class="card mb-3 shadow-sm">
        <div class="card-body text-center">
          <h5 class="card-title">Estado de Aparcamiento</h5>
          <div id="statusPanel">
            <p class="text-muted">No has aparcado tu vehículo aún.</p>
            <button id="btnAparcar" class="btn btn-success btn-lg">Aparcar Aquí</button>
          </div>
          
          <div id="activePanel" class="d-none mt-2">
            <div class="row mb-3">
              <div class="col-6 border-end">
                <small class="text-muted d-block">Distancia al Coche</small>
                <strong id="distanciaValor" class="fs-4">-- m</strong>
              </div>
              <div class="col-6">
                <small class="text-muted d-block">Tiempo Transcurrido</small>
                <strong id="tiempoValor" class="fs-4">--:--</strong>
              </div>
            </div>
            <button id="btnFinalizar" class="btn btn-danger">Finalizar Aparcamiento</button>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="card flex-grow-1 shadow-sm h-100" style="min-height: 550px;">
        <div id="map" class="w-100 h-100 rounded"></div>
      </div>

    </div>

    <!-- Columna Derecha: Historial -->
    <div class="col-lg-4 d-flex flex-column">
      <div class="card flex-grow-1 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Historial</h5>
          <button id="btnSync" class="btn btn-sm btn-outline-primary" title="Sincronizar en la nube">☁️ Sync</button>
        </div>
        <div class="card-body p-0 overflow-auto" id="historialLista" style="max-height: 600px;">
          <!-- Items generados en JS -->
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Modal Login -->
<div class="modal fade" id="modalLogin" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Iniciar Sesión para Guardar en la Nube</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Usuario</label>
          <input type="text" class="form-control" id="loginUser" placeholder="Cualquier nombre" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Contraseña</label>
          <input type="password" class="form-control" id="loginPass" placeholder="(usa 1234)" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" id="btnSubmitLogin" class="btn btn-primary">Entrar</button>
      </div>
    </div>
  </div>
</div>

<script>
  // Variables globales que le pasamos al frontend
  window.USER_LOGGED_IN = "<%= user ? user.username : '' %>";
</script>

<%- include('partials/footer') %>
